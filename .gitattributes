# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts
*.sh text eol=lf
*.bat text eol=crlf

# Go files
*.go text eol=lf
go.mod text eol=lf
go.sum text eol=lf

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# Markdown files
*.md text eol=lf

# Systemd service files
*.service text eol=lf

# Binary files
*.exe binary
*.dll binary
*.so binary
*.dylib binary
